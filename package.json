{
  "name": "@perkos/shared-client",
  "version": "0.1.1",
  "description": "Shared client lib for PerkOS apps: wallet auth, API client, Firebase init, React hooks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@perkos/shared-types": "^0.1.0",
    "firebase": "^10 || ^11 || ^12",
    "react": "^18 || ^19",
    "viem": "^2"
  },
  "peerDependenciesMeta": {
    "@perkos/shared-types": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "firebase": "^11.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "viem": "^2.21.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PerkOS-xyz/PerkOS-Shared-Client"
  },
  "keywords": [
    "perkos",
    "wallet",
    "firebase",
    "auth",
    "viem",
    "react"
  ],
  "author": "PerkOS <julio.cruz@eb-ms.net>",
  "license": "MIT"
}
